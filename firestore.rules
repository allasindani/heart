// Collection: jobs
// Document ID: {jobId}
// Fields:
//   - employerId: string (required)
//   - title: string (required)
//   - company: string (required)
//   - location: string (required)
//   - type: string (required)
//   - description: string (required)
//   - requirements: list (required)
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (required)
//   - status: string (required)
//   - salary: string (optional)
//
// Collection: applications
// Document ID: {appId}
// Fields:
//   - jobId: string (required)
//   - seekerId: string (required)
//   - employerId: string (required)
//   - status: string (required)
//   - timestamp: timestamp (required)
//   - seekerName: string (required)
//   - seekerPhoto: string (optional)
//
// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - displayName: string (required) - User's display name
//   - photoURL: string (optional) - Profile picture URL
//   - status: string (optional) - WhatsApp-style status text
//   - lastSeen: timestamp (optional) - Last online timestamp
//   - isOnline: bool (optional) - Current online status
//   - datingProfile: map (optional) - Dating specific data
//   - role: string (required) - 'user' or 'admin'
//   - category: string (required) - Membership tier
//   - points: number (required) - User points
//   - isVerified: bool (optional) - Verification status
//   - jobRole: string (optional) - 'employer' or 'seeker'
//
// Collection: settings
// Document ID: {settingId}
// Fields:
//   - pointsPerPost: number
//   - pointsPerComment: number
//   - pointsPerLike: number
//   - moneyPerPoint: number
//   - tierPrices: map
//   - tierDurations: map
//   - paymentMethods: list
//
// Collection: chats
// Document ID: {chatId}
// Fields:
//   - participants: list (required) - Array of user UIDs
//   - type: string (required) - 'private' or 'group'
//   - lastMessage: map (optional) - Last message preview
//   - updatedAt: timestamp (required) - Last update time
//
// Collection: chats/{chatId}/messages
// Document ID: {messageId}
// Fields:
//   - senderId: string (required) - UID of sender
//   - text: string (optional) - Message text
//   - type: string (required) - 'text', 'image', etc.
//   - timestamp: timestamp (required) - Message time
//   - status: string (required) - 'sent', 'delivered', 'seen'
//   - reactions: map (optional) - User UID to emoji string
//
// Collection: statuses
// Document ID: {statusId}
// Fields:
//   - userId: string (required) - UID of creator
//   - type: string (required) - 'text', 'image', etc.
//   - content: string (required) - Content or URL
//   - createdAt: timestamp (required) - Creation time
//
// Collection: posts
// Document ID: {postId}
// Fields:
//   - userId: string (required) - UID of creator
//   - content: string (required) - Post text
//   - media: list (optional) - Array of media URLs
//   - likes: list (required) - Array of user UIDs who liked
//   - createdAt: timestamp (required) - Creation time
//   - isAd: bool (required) - Whether it's an ad
//   - commentCount: number (required)
//
// Collection: payment_proofs
// Document ID: {proofId}
// Fields:
//   - userId: string (required)
//   - userName: string (required)
//   - tier: string (required)
//   - amount: number (required)
//   - proofUrl: string (required)
//   - status: string (required) - 'pending', 'approved', 'rejected'
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/connection {
      allow read: if true;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "alasindani2020@gmail.com" && request.auth.token.email_verified == true));
    }

    function isParticipant(chatId) {
      return isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'role', 'category', 'points']) &&
             data.uid is string && 
             (data.uid == request.auth.uid || isAdmin()) &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.role in ['user', 'admin'] &&
             data.category in ['General', 'Bronze', 'Silver', 'Gold', 'Platinum'] &&
             data.points is number &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string) &&
             (!('firstName' in data) || data.firstName is string) &&
             (!('lastName' in data) || data.lastName is string) &&
             (!('status' in data) || data.status == null || data.status is string) &&
             (!('notificationsEnabled' in data) || data.notificationsEnabled is bool) &&
             (!('isOnline' in data) || data.isOnline == null || data.isOnline is bool) &&
             (!('lastSeen' in data) || data.lastSeen == null || data.lastSeen is timestamp) &&
             (!('suspended' in data) || data.suspended == null || data.suspended is bool) &&
             (!('datingProfile' in data) || data.datingProfile == null || data.datingProfile is map) &&
             (!('jobRole' in data) || data.jobRole in ['employer', 'seeker']) &&
             (!('affiliateCode' in data) || data.affiliateCode is string) &&
             (!('referredBy' in data) || data.referredBy == null || data.referredBy is string) &&
             (!('referralCount' in data) || data.referralCount is number) &&
             (!('isVerified' in data) || data.isVerified is bool);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'type', 'timestamp', 'status']) &&
             data.senderId == request.auth.uid &&
             data.type in ['text', 'image', 'video', 'voice', 'document'] &&
             data.status in ['sent', 'delivered', 'seen'] &&
             (data.text == null || (data.text is string && data.text.size() < 10000));
    }

    function isValidPost(data) {
      return data.userId == request.auth.uid &&
             data.content is string && data.content.size() < 5000 &&
             data.likes is list &&
             data.createdAt is timestamp;
    }

    function isValidStatus(data) {
      return data.userId == request.auth.uid &&
             data.type is string &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['userId', 'postId', 'text', 'createdAt', 'userName']) &&
             data.userId == request.auth.uid &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.createdAt is timestamp;
    }

    function isValidJob(data) {
      return data.keys().hasAll(['employerId', 'title', 'company', 'location', 'type', 'description', 'requirements', 'createdAt', 'updatedAt', 'status']) &&
             data.employerId == request.auth.uid &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isVerified == true &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.company is string && data.company.size() > 0 && data.company.size() < 200 &&
             data.location is string &&
             data.type in ['Full-time', 'Part-time', 'Contract', 'Remote'] &&
             data.description is string && data.description.size() < 10000 &&
             data.requirements is list &&
             data.status in ['open', 'closed'];
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['jobId', 'seekerId', 'employerId', 'status', 'timestamp', 'seekerName']) &&
             data.seekerId == request.auth.uid &&
             data.status == 'applied' &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() || (resource != null && resource.data.isFeaturedSingle == true);
      allow create: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && isValidMessage(request.resource.data);
        allow update: if isParticipant(chatId) && (
          (request.resource.data.senderId == request.auth.uid && isValidMessage(request.resource.data)) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'reactions']))
        );
      }
    }

    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidStatus(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'commentCount'])) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidComment(request.resource.data);
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    match /payment_proofs/{proofId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.fromId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.toId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid || isAdmin());
    }

    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidJob(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.employerId == request.auth.uid && isValidJob(request.resource.data)) ||
        isAdmin()
      );
      allow delete: if isAuthenticated() && (resource.data.employerId == request.auth.uid || isAdmin());
    }

    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (
        resource.data.seekerId == request.auth.uid || 
        resource.data.employerId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidApplication(request.resource.data);
      allow update: if isAuthenticated() && (
        (resource.data.employerId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
